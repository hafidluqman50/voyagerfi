PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/voyagerfi?sslmode=disable

# Agent wallet private key (used for Arbitrum tx + 0G Chain tx)
AGENT_PRIVATE_KEY=

# ── 0G Chain (verifiability layer) ──────────────────────────────────────────
OG_RPC_URL=https://evmrpc.0g.ai

# ── 0G Compute (DeepSeek v3 via TEE) ────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_URL=

# ── 0G Storage ───────────────────────────────────────────────────────────────
STORAGE_INDEXER_URL=https://indexer-storage-turbo.0g.ai
STORAGE_ENDPOINT=

# ── Pyth Oracle ───────────────────────────────────────────────────────────────
PYTH_CONTRACT=0x2880ab155794e7179c9ee2e38200202908c17b43

# ── 0G Chain contract addresses (deploy with: forge script DeployOG.s.sol) ──
AGENT_REGISTRY_ADDRESS=
DECISION_LOG_ADDRESS=
STORAGE_ANCHOR_ADDRESS=

# ── Arbitrum — Vault custody + Uniswap V3 execution ─────────────────────────
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
VAULT_ADDRESS=
# Set to true for Arbitrum One mainnet. Default: false (Sepolia testnet)
ARBITRUM_MAINNET=false
